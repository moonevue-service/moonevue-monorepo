# ============================================
# Moonevue — Template de Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.
#   cp .env.example .env
#
# Para PRODUÇÃO, copie para .env.prod:
#   cp .env.example .env.prod
#   e ajuste os valores conforme o ambiente.

# ---------- Timezone ----------
TZ=America/Sao_Paulo

# ---------- PostgreSQL ----------
POSTGRES_DB=moonevue
POSTGRES_USER=moonevue
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA

# ---------- Datasource ----------
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/moonevue
SPRING_DATASOURCE_USERNAME=moonevue
SPRING_DATASOURCE_PASSWORD=TROQUE_ESTA_SENHA

# ---------- Auth Service ----------
AUTH_BASE_URL=http://auth:8081
AUTH_INTERNAL_TOKEN=TROQUE_ESTE_TOKEN
AUTH_COOKIE_DOMAIN=localhost
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_NAME=sid
AUTH_COOKIE_MAX_AGE=1800

# ---------- Storage (certificados bancários) ----------
STORAGE_CERTS_DIR=/data/certs

# ---------- Webhooks ----------
WEBHOOK_HMAC_SECRET=TROQUE_ESTE_HMAC

# ============================================
# Apenas para PRODUÇÃO (docker-compose.prod.yml)
# ============================================

# Imagens (Docker Hub, GHCR, etc.)
# AUTH_IMAGE=ghcr.io/seu-usuario/moonevue-auth:latest
# GATEWAY_IMAGE=ghcr.io/seu-usuario/moonevue-gateway:latest
# FINANCE_IMAGE=ghcr.io/seu-usuario/moonevue-finance:latest

# Cookies em produção
# AUTH_COOKIE_DOMAIN=seu-dominio.com
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=Strict

