# ============================================
# Moonevue — Variáveis de Desenvolvimento
# ============================================
# Este arquivo é lido automaticamente pelo docker-compose.
# NÃO commite este arquivo com credenciais reais.
# Use .env.example como template para documentação.

# ---------- Timezone ----------
TZ=America/Sao_Paulo

# ---------- PostgreSQL ----------
POSTGRES_DB=moonevue
POSTGRES_USER=moonevue
POSTGRES_PASSWORD=moone_data_vue

# ---------- Datasource (todos os serviços usam o mesmo DB) ----------
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/moonevue
SPRING_DATASOURCE_USERNAME=moonevue
SPRING_DATASOURCE_PASSWORD=moone_data_vue

# ---------- Auth service ----------
AUTH_BASE_URL=http://auth:8081
AUTH_INTERNAL_TOKEN=super-secret-dev
AUTH_COOKIE_DOMAIN=localhost
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_NAME=sid
AUTH_COOKIE_MAX_AGE=1800

# ---------- Storage ----------
STORAGE_CERTS_DIR=/data/certs

# ---------- Webhooks ----------
WEBHOOK_HMAC_SECRET=dev-hmac-secret

