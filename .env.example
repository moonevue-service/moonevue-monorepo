# ============================================
# Moonevue Monorepo - Root Environment Template
# ============================================

# ---------- Frontend ----------
NEXT_PUBLIC_API_BASE_URL=

# ---------- Shared timezone ----------
TZ=America/Sao_Paulo

# ---------- PostgreSQL ----------
POSTGRES_DB=moonevue
POSTGRES_USER=moonevue
POSTGRES_PASSWORD=change-me

# ---------- Spring datasource ----------
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/moonevue
SPRING_DATASOURCE_USERNAME=moonevue
SPRING_DATASOURCE_PASSWORD=change-me

# ---------- Auth / Internal ----------
AUTH_BASE_URL=http://auth:8081
AUTH_INTERNAL_TOKEN=change-me-internal-token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_NAME=sid
AUTH_COOKIE_MAX_AGE=1800

# ---------- Storage ----------
STORAGE_CERTS_DIR=/data/certs

# ---------- Webhooks ----------
WEBHOOK_HMAC_SECRET=change-me-webhook-secret
