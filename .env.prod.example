# Timezone
TZ=America/Sao_Paulo

# Imagens (pode ser Docker Hub ou GHCR)
# Ex: Docker Hub -> AUTH_IMAGE=docker.io/seuusuario/moonevue-auth:prod
# Ex: GHCR -> AUTH_IMAGE=ghcr.io/MarceloCPJunior/moonevue-auth:prod
AUTH_IMAGE=docker.io/seuusuario/moonevue-auth:prod
GATEWAY_IMAGE=docker.io/seuusuario/moonevue-gateway:prod
FINANCE_IMAGE=docker.io/seuusuario/moonevue-finance:prod

# Banco (em produção prefira Postgres gerenciado; aqui está local no compose)
POSTGRES_DB=moonevue
POSTGRES_USER=moonevue
POSTGRES_PASSWORD=troque-este-segredo

# Datasources
SPRING_DATASOURCE_USERNAME=moonevue
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}

# Se usar Postgres do compose:
SPRING_DATASOURCE_URL_AUTH=jdbc:postgresql://postgres:5432/${POSTGRES_DB}
SPRING_DATASOURCE_URL_GATEWAY=
SPRING_DATASOURCE_URL_FIN=jdbc:postgresql://postgres:5432/${POSTGRES_DB}

# Integração entre serviços
AUTH_INTERNAL_TOKEN=troque-este-segredo-interno
AUTH_COOKIE_NAME=sid

# Cookies (ajuste conforme topologia do front)
# Se front e gateway estão no MESMO domínio -> Lax e Secure=true (se HTTPS)
AUTH_COOKIE_DOMAIN=seu-dominio.com
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_MAX_AGE=1800

# Webhooks no gateway
WEBHOOK_HMAC_SECRET=troque-este-hmac

# Finance
# Gere 32 bytes base64: Linux/Mac -> head -c 32 /dev/urandom | base64
FINANCE_CRYPTO_SECRET=BASE64_DE_32_BYTES